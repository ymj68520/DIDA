# 信任锚公钥配置示例
# 复制此文件为 trust_anchor.env 并填写实际值

# PK_Top: 顶级权威机构的公钥，用于V1验签
# 由 scripts/keygen/generate_keys.py 生成
PK_TOP=0x04ab189a7e464711705cfd1912c5b80e42cd2e842bb2c8d93423d747e90a94bbde23fd5446f2bd78579b52896deeb5ad374ea907eff6cedd16729b6fb49bc09e87

# 注意：
# 1. PK_Top必须与部署合约时使用的SK_Top对应
# 2. PK_Top由scripts/keygen/generate_keys.py生成
# 3. 网关启动时从本文件加载PK_Top，不依赖任何网络查询
# 4. 此文件包含敏感配置，请勿提交到Git仓库